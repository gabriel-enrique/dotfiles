# ~/.gitconfig - Git configuration
[user]
	name = Gabriel Enrique
	email = gabrielenrique.abel@gmail.com

[init]
	defaultBranch = master

[core]
	editor = nvim
	excludesfile = ~/.gitignore_global

[pull]
	ff = only

[push]
	autoSetupRemote = true

[fetch]
	prune = true

[commit]
	verbose = true

[merge]
	conflictStyle = zdiff3

[diff]
	algorithm = histogram

[color]
	ui = auto

[alias]
	reword = "!f() { if [ $# -eq 0 ]; then git commit --amend; elif [ $# -eq 1 ]; then git commit --amend -m \"$1\"; else echo 'usage: git reword [\"message\"]' >&2; return 1; fi; }; f"
	append = "!f() { [ $# -eq 0 ] || { echo 'usage: git append (no args)' >&2; return 1; }; git commit --amend --no-edit; }; f"
	undo = "!f() { [ $# -eq 0 ] || { echo 'usage: git undo (no args)' >&2; return 1; }; git reset --soft HEAD~1; }; f"
	staged = diff --staged
	logg = log --oneline --graph --decorate --all
	logv = log --graph --all --pretty=format:\"%C(auto)%h%C(auto)%d%Creset %s %C(green)[%an %C(blue)(%ar)%C(green)]%Creset\"

# Per-machine overrides (not tracked). Missing file is a silent no-op.
# Edit ~/.gitconfig.local by hand — do not use `git config --global`,
# since that writes through the symlink into the tracked file.
[include]
	path = ~/.gitconfig.local
