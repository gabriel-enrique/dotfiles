# ~/.inputrc — readline configuration
# Applies to bash and other readline-enabled tools (psql, irb, etc.)

# Inherit any system-wide defaults
$include /etc/inputrc

# ── Completion ────────────────────────────────────────────────────────────────
#   completion-ignore-case      -- case-insensitive matching
#   completion-map-case         -- treating - and _ as equivalent
#   show-all-if-ambiguous       -- showing all matches on first Tab
#   show-all-if-unmodified      -- same, when the line hasn't been edited
#   colored-stats               -- coloring completions via LS_COLORS
#   colored-completion-prefix   -- highlighting the matched prefix
#   visible-stats               -- type indicators (/ * @) like ls -F
#   mark-symlinked-directories  -- trailing / on symlinked directories
#   page-completions            -- pagination of long lists
#   skip-completed-text         -- skipping text already right of the cursor
set completion-ignore-case on
set completion-map-case on
set show-all-if-ambiguous on
set show-all-if-unmodified on
set colored-stats on
set colored-completion-prefix on
set visible-stats on
set mark-symlinked-directories on
set page-completions off
set skip-completed-text on

# ── Bell ──────────────────────────────────────────────────────────────────────
#   bell-style  -- audible bell on ambiguous completion / errors
set bell-style none
